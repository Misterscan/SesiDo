/*
    SesiDo Safe File Access
    File operations wrapped in try-catch blocks to prevent crashes
*/
export fn readFile(path: str) -> str? {try {let content = read_file(path); return content} catch (err) {print "[SesiDo]: Failed to read file at:" path; print "Details:" err; return null}}
export fn writeFile(path: str, content: str) {try {write_file(path, content)} catch (err) {print "[SesiDo]: Failed to write to file at:" path; print "Details:" err}}
export fn writeImage(path: str, content: str) {try {write_image(path, content)} catch (err) {print "[SesiDo]: Failed to write image to file at:" path; print "Details:" err}}
export fn appendFile(path: str, content: str) {try {let existing = ""; try {existing = read_file(path)} catch (e) {}if len(existing) > 0 {if slice(existing, len(existing) - 1, len(existing)) != "\n" {existing = existing + "\n"}}write_file(path, existing + content)} catch (err) {}}
export let wsRoot = trim(exec("pwd"));