// SesiDo Engine
// Imports
allow "std/db" in with DB; allow "std/browser" in with{launch}; allow "./agent/persona" in with Persona; allow "./utils/safe" in with Safe; allow "./helpers/timestamp" in with{localTime, universalTime, formattedTime}
// Variables
let workspaceRoot = Safe.wsRoot+"/SesiDo/"; let dbDir=workspaceRoot+"database/"; let artifactsDir=workspaceRoot+".artifacts/"; let logsDir=workspaceRoot+"logs/"; let codeDir=artifactsDir+"code/"; let imageDir=artifactsDir+"images/"; let svgDir=artifactsDir+"svgs/"; let summaryDir=artifactsDir+"summaries/"; let researchDir=artifactsDir+"research/"; let browserDir=artifactsDir+"browser/"
// Make sure directories exist
make_dir(dbDir); make_dir(dbDir+".agent/"); make_dir(artifactsDir); make_dir(logsDir); make_dir(codeDir); make_dir(imageDir); make_dir(svgDir); make_dir(summaryDir); make_dir(researchDir); make_dir(browserDir)
// Database
let db=DB.db_open(dbDir+"agent.db", "enter-your-super-secret-password-here"); let history=db.collection("history"); let sessions=db.collection("sessions"); let sessionLogPath=""
// Current session ID and timestamps
export let currentSessionId="default"; export let localTime=localTime("basic"); export let universalTime=universalTime(); export let formattedTime=formattedTime()
// System instructions, tools, and persona
let instructions=Persona.getSystemInstruction(); let toolsMD=Persona.getToolsMD(); let agentBasicsMD=Persona.getAgentBasicsMD(); let agentOptionalMD=Persona.getAgentOptionalMD(); let agentOtherMD=Persona.getAgentOtherMD(); let agentTools=Persona.getAgentTools()
export let sesiDoModels = ["SesiDo", "SesiDo-Heavy", "SesiDo-Pro", "SesiDo-Lite", "SesiDo-Lite-Power", "SesiDo-Flash", "SesiDo-Image", "SesiDo-Image-Lite"]; export let ogNames = ["gemini-3.6-flash", "gemini-3.5-flash", "gemini-3.1-pro-preview", "gemini-3.1-flash-lite", "gemini-3.5-flash-lite", "gemini-3-flash-preview", "gemini-3.1-flash-image", "gemini-3.1-flash-lite-image"]
export fn setModel(alias: str, model_name: str){if alias!=null{set_alias(alias, model_name)}else{set_alias(sesiDoModels[0], ogNames[0]); set_alias(sesiDoModels[1], ogNames[1]); set_alias(sesiDoModels[2], ogNames[2]); set_alias(sesiDoModels[3], ogNames[3]); set_alias(sesiDoModels[4], ogNames[4]); set_alias(sesiDoModels[5], ogNames[5]); set_alias(sesiDoModels[6], ogNames[6]); set_alias(sesiDoModels[7], ogNames[7])}}
// Temperature and thinking level settings
export let minimalTemp=0.1; export let lowTemp=0.3; export let mediumTemp=0.5; export let highTemp=0.7; export let minimalThink="minimal"; export let lowThink="low"; export let mediumThink="medium"; export let highThink="high"; export let streamOutput=true; export let searchGoogle=true; export let square="1:1"; export let portrait="9:16"; export let landscape="16:9"; export let tv="4:3"; export let mini="512"; export let small="1K"; export let medium="2K"; export let large="4K"
// Base brain from persona
fn get_base_brain(){memory base_brain{"systemInstruction:" instructions " toolsMD:" toolsMD " agentBasicsMD:" agentBasicsMD " agentOptionalMD:" agentOptionalMD " agentOtherMD:" agentOtherMD " agentTools:" agentTools " Note:The '.artifacts/' directory already exists. Use it to save generated assets. Do not try to create it."}; return base_brain}
let brain=get_base_brain()
// Load existing session or create new one
setModel()
fn loadSession(sid){currentSessionId=sid; let sessionDir=logsDir+sid+"/"; make_dir(sessionDir); sessionLogPath=sessionDir+"agent-"+formattedTime+".log"; let prevMessages=history.find({"sessionId":sid});let conversation=""; for msg in prevMessages{conversation=conversation+msg["role"]+":"+msg["content"]+"; "}let jsonRep={"stable_facts":[], "user_preferences":[], "project_state":[], "agent_identity":[], "style_preferences":[], "metaphors":[], "discard":[]}; let brainJson=model("SesiDo-Lite-Power"){"Summarize the durable memory from this conversation. Rules:-Keep only stable facts, user preferences, project identity, unresolved tasks, agent identity, style preferences, and useful metaphors.-agent_identity must contain only literal operational facts and boundaries.-Do not include metaphors in agent_identity. Put all figurative descriptions only in metaphors.-Do not preserve poetic phrasing unless explicitly labeled as style or metaphor.-Label metaphors as metaphors, not facts.-Put hallucinations, temporary task details, stale claims, unsupported claims, old names, and conversational filler in discard. Conversation:" conversation " Return a JSON object with the following keys:" jsonRep}; let clean=swap(brainJson, "```json", ""); clean=swap(clean, "```", ""); brainJson=clean; let brainSummary=structured_output({stable_facts:str, user_preferences:str, project_state:str, agent_identity:str, style_preferences:str, metaphors:str, discard:str})(brainJson); print "[SesiDo]: Loaded session '" sid "' with " str(len(prevMessages))" previous messages.";Safe.appendFile(dbDir+".agent/"+sid+"-brain-summary.json", brainSummary); let memoryBlock=" SESSION MEMORY:Stable facts:"+brainSummary["stable_facts"]+" User preferences:"+brainSummary["user_preferences"]+" Project state:"+brainSummary["project_state"]+" Agent identity:"+brainSummary["agent_identity"]+" Style preferences:"+brainSummary["style_preferences"]+" Metaphors:"+brainSummary["metaphors"]+" Rules:-Metaphors are optional style references, not factual claims. Do not use them in ordinary greetings unless the user asks for expressive or philosophical language.-Do not mention the session memory to the user unless they ask about it.-Do not mention your tools or capabilities to the user unless they ask about them.-Focus on the user's goals and requests, and use your tools to assist them if required. "; brain=get_base_brain()+memoryBlock; let existing=sessions.find({"id":sid}); if len(existing)==0{sessions.insert({"id":sid, "created":universalTime})}}
loadSession("default")
// String manipulation
fn quote(s){let text=str(s); text=swap(text, "\"", "\\\""); return "\""+text+"\""}
fn sanitize(name){let s=str(name); s=swap(s, " ", "_"); s=swap(s, "/", "-"); s=swap(s, "{", ""); s=swap(s, "}", ""); s=swap(s, ":", ""); s=swap(s, "\"", ""); s=swap(s, "'", ""); s=swap(s, "?", ""); s=swap(s, "*", ""); s=swap(s, "<", ""); s=swap(s, ">", ""); s=swap(s, "|", ""); if len(s)>40{s=slice(s, 0, 40)}return s}
// File system operations
fn newDir(args){let path=null; if type(args)=="object"{path=args["path"]}else{path=args}if path==null{return "Error: makeDir requires a path."}try{Safe.makeDir(path); return "Success: Directory created: "+path}catch(e){return "Error creating directory:"+str(e)}}
fn read(args){let path=null; if type(args)=="object"{path=args["path"]}else{path=args}if path==null{return "Error: read requires a path."}let userInput=input("SesiDo Agent is trying to read file "+path+". Is this okay?: (y/n) "); if to_lower(trim(userInput))!="y"{return "Error: User rejected read request."} if to_lower(trim(userInput))=="y"{try{let content=Safe.readFile(path); if content!=null{return content}}catch(e){}return null}}
fn write(args){let path=null; let content=null; if type(args)=="object"{path=args["path"]; content=args["content"]}if path==null||content==null{return "Error: write requires path and content."}let userInput=input("SesiDo Agent is trying to write to file "+path+". Is this okay?: (y/n) "); if to_lower(trim(userInput))!="y"{return "Error: User rejected write request."} if to_lower(trim(userInput))=="y"{try{Safe.writeFile(path, content); return "Success: Wrote to "+path}catch(e){return "Error writing file:"+str(e)}}}
fn remove(args){let path=null; if type(args)=="object"{path=args["path"]}else{path=args}if path==null{return "Error: remove requires a path."}let userInput=input("SesiDo Agent is trying to remove file "+path+". Is this okay?: (y/n) "); if to_lower(trim(userInput))!="y"{return "Error: User rejected remove request."}if to_lower(trim(userInput))=="y"{prompt success{"Successfully removed "path}; prompt error{"Error removing "path}try {trash(path, false); return success}catch(e){return error+str(e)}}}
fn move(args){let path=null; let dest=null; if type(args)=="object"{path=args["path"]; dest=args["destination"]}else if type(args)=="array"{path=args[0]; dest=args[1]}else{path=args}if path==null||dest==null{return "Error: move requires a source and destination."}let userInput=input("SesiDo Agent is trying to move "+path+" to "+dest+". Is this okay?: (y/n) "); if to_lower(trim(userInput))!="y"{return "Error: User rejected move request."}if to_lower(trim(userInput))=="y"{try{Safe.moveFile(path, dest); return "Success: Moved "+path+" to "+dest}catch(e){return "Error moving file:"+str(e)}}}
fn list(args){let path=Safe.wsRoot; if type(args)=="object"{if args["path"]!=null{path=args["path"]}}else if args!=null{path=args}try{let files=list_dir(path); return files}catch(e){return "Error listing directory:"+str(e)}}
fn append(args){let path=null; let content=null; if type(args)=="object"{path=args["path"]; content=args["content"]}if path==null||content==null{return "Error: appendFile requires path and content."}try{Safe.appendFile(path, content); return "Success: Appended to "+path}catch(e){return "Error appending to file:"+str(e)}}
fn safeRun(args){let cmd=null; if type(args)=="object"{cmd=args["command"]; if cmd==null{cmd=args["cmd"]}}else{cmd=args}if cmd==null{return "Error: safeRun requires a script path or command."}let userInput=input("SesiDo Agent is trying to run command: "+cmd+". Is this okay?: (y/n) "); if to_lower(trim(userInput))!="y"{return "Error: User rejected run request."}if to_lower(trim(userInput))=="y"{try{let output=cmd; if contains(cmd, ".sesi")&&!contains(cmd, "sesi "){output=sesi(cmd, true)}else{output=exec(cmd)}return output}catch(e){return "Execution error:"+str(e)}}}
fn eval(args){let code=null; if type(args)=="object"{code=args["code"]}else{code=args}if code==null{return "Error: eval requires code."}let userInput = input("SesiDo Agent is trying to eval code: "+code+". Is this okay?: (y/n) "); if to_lower(trim(userInput))!="y"{return "Error: User rejected eval request."}if to_lower(trim(userInput))=="y"{try{let result=exec("sesi -l -e "+quote(code)); return result}catch(e){return "Error evaluating code: "+str(e)}}}
fn httpGet(args){let url=null; let headers={}; if type(args)=="object"{url=args["url"]; if args["headers"]!=null{headers=args["headers"]}}else{url=args}if url==null{return "Error: httpGet requires a URL."}try{let response=web_get(url, headers); return response}catch(e){return "HTTP GET error:"+str(e)}}
fn httpSend(args){let url=null; let data=null; let headers={}; if type(args)=="object"{url=args["url"]; data=args["data"]; if args["headers"]!=null{headers=args["headers"]}}if url==null{return "Error: httpSend requires a URL."}try{let response=web_send(url, data, headers); return response}catch(e){return "HTTP SEND error:"+str(e)}}
// SesiDo Agents
export fn writeCode(args){let query=null; if type(args)=="object"{if args["query"]!=null{query=args["query"]}else if args["text"]!=null{query=args["text"]}else if args["description"]!=null{query=args["description"]}}else{query=args}if(query==null||query=="")&&type(args)=="object"&&len(keys(args))==1{let firstKey=keys(args)[0]; query=args[firstKey]}if query==null||query==""{return "Error: writeCode requires a query or request description."}print "[SesiDo]: Writing code for:" query; let codeResponse=""; try{codeResponse=model("SesiDo-Pro"){thinkingLevel: mediumThink, temperature: lowTemp}{brain " Write code for the following request (avoid verbatim recitation of large standard texts; paraphrase or draft custom versions if needed): " query}}catch(e){print "[SesiDo]: ⚠ Code generation failed(" str(e)"). Trying SesiDo-Flash..."; try{codeResponse=model("SesiDo-Flash"){thinkingLevel: mediumThink, temperature: mediumTemp}{brain "Write code for: " query}}catch(e2){return "Code generation failed due to safety or technical blocks."}}let filename=codeDir+sanitize(query)+"-"+formattedTime+"-code.md"; Safe.writeFile(filename, codeResponse); print "[SesiDo]: Wrote code for" query "and saved to" codeDir "!"; return codeResponse}
export fn debugCode(args){let targetFile=null; let query=null; if type(args)=="object"{if args["path"]!=null{targetFile=args["path"]}else if args["file"]!=null{targetFile=args["file"]}else if args["query"]!=null{query=args["query"]}}else{query=args}if targetFile==null&&query==null{print "[SesiDo]:Enter the path to the code file you want to debug..." targetFile=input("[You]: ")}else if targetFile==null&&query!=null{let words=split(query, " "); for w in words{if contains(w, ".")&&!contains(w, "search"){targetFile=w}}}if targetFile==null{return "No file specified for debugging."}let codeContent=Safe.readFile(targetFile); if codeContent==null{return "Failed to read file."}print "[SesiDo]: Debugging code in file:" targetFile; let preCode=model("SesiDo-Pro"){temperature: lowTemp}{brain " Debug the following code and provide suggestions for improvements or fixes:" codeContent}; Safe.writeFile(codeDir+sanitize(targetFile)+"-"+formattedTime+"-pre-debug.md", preCode); let debugResponse=model("SesiDo-Lite"){temperature: mediumTemp}{brain " Apply the following debugging suggestions to the code in " targetFile " and provide the improved code:" preCode}; Safe.writeFile(codeDir+sanitize(targetFile)+"-"+formattedTime+"-debug.md", debugResponse); print "[SesiDo]: Debugged code in" targetFile "and saved results to" codeDir "!"; return debugResponse}
export fn research(args){let query=null; if type(args)=="object"{if args["query"]!=null{query=args["query"]}else if args["topic"]!=null{query=args["topic"]}}else{query=args}if query==null||query==""{return "Error: research requires a query."}print "[SesiDo]: Conducting research on:" query; let researchResponse=""; try{researchResponse=model("SesiDo-Flash"){thinkingLevel: mediumThink, temperature: lowTemp, search, max_tokens: 500}{brain " Research the following topic and provide a summary of findings (paraphrase sources to avoid recitation blocks) Must return:\n- sources_used: list of URLs or document paths\n- claims: 3 to 7 key claims\n- confidence: low|medium|high\n- unsupported/speculative claims: list\n- synthesis: final prose " query}}catch(e){print "[SesiDo]: ⚠ Research failed(" str(e)"). Retrying with SesiDo-Lite..."; try{researchResponse=model("SesiDo-Lite"){thinkingLevel: lowThink, temperature: lowTemp}{brain "Research:" query}}catch(e2){return "Research failed due to safety or technical blocks."}}let filename=researchDir+sanitize(query)+"-"+formattedTime+"-research.md"; Safe.writeFile(filename, researchResponse); print "[SesiDo]: Research completed on" query "and saved results to" researchDir "!"; return researchResponse}
export fn summarize(args){let text=null; if type(args)=="object"{if args["text"]!=null{text=args["text"]}else if args["path"]!=null{text=args["path"]}else if args["query"]!=null{text=args["query"]}}else{text=args}if text==null||text==""{return "Error: summarize requires text or a file path."}let query=text; if text==null||text==""{return "No text provided for summarization."}if len(text)<100&&contains(text, "."){let content=Safe.readFile(text); if content!=null{text=content}}print "[SesiDo]: Summarizing..."; let summaryResponse=""; try{summaryResponse=model("SesiDo-Lite"){thinkingLevel: minimalThink, temperature: lowTemp, max_tokens: 1024}{"Summarize the following text:" text}}catch(e){print "[SesiDo]: ⚠ Summarization failed(" str(e)"). Retrying with SesiDo..."; try{summaryResponse=model("SesiDo"){thinkingLevel: minimalThink, temperature: lowTemp}{brain "Summarize:" text}}catch(e2){return "Summarization failed due to safety or technical blocks."}}let filename=summaryDir+sanitize(query)+"-"+formattedTime+"-summary.md"; Safe.writeFile(filename, summaryResponse); print "[SesiDo]: Summarized text and saved summary to" summaryDir "!"; return summaryResponse}
export fn calculator(args){let expression=null; if type(args)=="object"{if args["expression"]!=null{expression=args["expression"]}else if args["query"]!=null{expression=args["query"]}}else{expression=args}if expression==null||expression==""{return "Error: calculator requires a mathematical expression."}print "[SesiDo]: Calculating:" expression; let calcResponse=model("SesiDo-Flash"){thinkingLevel: minimalThink, temperature: minimalTemp, stream: streamOutput}{brain " Calculate the following expression and provide the result:" expression}; print calcResponse; return calcResponse}
export fn createSVG(args){let query=null; if type(args)=="object"{if args["query"]!=null{query=args["query"]}else if args["description"]!=null{query=args["description"]}}else{query=args}if query==null||query==""{return "Error: createSVG requires a description."}print "[SesiDo]: Creating SVG for:" query; let svg_output_path=svgDir+sanitize(query)+"-"+formattedTime+".svg"; let svgResponse=false; svgResponse=model("SesiDo-Pro"){thinkingLevel: lowThink, temperature: mediumTemp}{"You are a Sesi programming language code generator.\nWrite a Sesi script using the 'std/draw' module to draw the SVG requested. The Sesi drawing API is:\n\n allow \"std/draw\" in with Draw\nDraw.clear()\n- Draw.circle(cx, cy, r, fill, options = {}) -- options keys: stroke, stroke-width, opacity, class, id\n- Draw.rect(x, y, w, h, fill, options = {}) options keys: rx, ry, opacity, class, id\n- Draw.line(x1, y1, x2, y2, stroke, options = {})\n- Draw.text(x, y, content, size, fill, options = {}) -- options keys: font-family, font-weight, opacity, class, id\n- Draw.ellipse(cx, cy, rx, ry, fill, options = {})\n- Draw.polygon(points_string, fill, options = {})\n- Draw.path(d_string, fill, options = {})\n- Draw.gradient(type, id, stops_array, options = {}) -- type is \"linear\" or \"radial\", stops_array is e.g. [{\"offset\": \"0%\", \"color\": \"red\"}, {\"offset\": \"100%\", \"color\": \"blue\"}]\n- Draw.style(cssText_string)\n- Draw.save_svg(output_path, width, height)\n -- \nsave output.\nRules:\n1. Always allow \"std/draw\" in with Draw at the beginning.\n2. Sesi does not use let or var or function definitions inside the drawing statements. Just call Draw functions.\n3. Make sure to call Draw.save_svg() at the end.\n4. Output ONLY the Sesi script code inside a ```sesi code block. Do not write any explanations before or after.\nOutput path to use: " svg_output_path "\nRequest to draw: " query}; svgResponse=split(svgResponse, "```sesi")[1]; svgResponse=split(svgResponse, "```")[0]; let filename=codeDir+sanitize(query)+"-"+formattedTime+"-svg.sesi"; Safe.writeFile(filename, svgResponse); if svgResponse != "" {let cmd=filename; try{sesi(cmd, true); print "[SesiDo]: Created and rendered SVG for"query"and saved to"svgDir"!"}catch(e){print "[SesiDo]: ⚠ Error rendering SVG:" str(e)}}print "[SesiDo]: Saved SVG sesi code for"query" to"codeDir"!"; return svgResponse}
export fn drawPixelArt(args){let query=null;if type(args)=="object"{if args["query"]!=null{query=args["query"]}else if args["description"]!=null{query=args["description"]}}else{query=args}if query==null||query==""{return "Error: drawPixelArt requires a description."}print "[SesiDo]: Creating pixel art for:" query; let png_output_path=imageDir+sanitize(query)+"-"+formattedTime+"-pixel-art.png"; let pixelArtResponse=false;pixelArtResponse=model("SesiDo-Lite-Power"){brain "You are a Sesi programming language code generator.\nWrite a Sesi script using the 'std/draw' module to draw pixel art based on the following description. Use a grid of squares to represent pixels, and choose colors that match the description. The Sesi drawing API is:\n\n allow \"std/draw\" in with Draw\nDraw.clear()\n- Draw.pixel(x, y, color)\n- Draw.pixel_grid(grid, palatte, scale, x, y)\n- Draw.save_png(path, width, height)\n -- \nsave output.\nRules:\n1. Always allow \"std/draw\" in with Draw at the beginning.\n2. Sesi does not use let or var or function definitions inside the drawing statements. Just call Draw functions.\n3. Make sure to call Draw.save_png() at the end.\n4. Output ONLY the Sesi script code inside a ```sesi code block. Do not write any explanations before or after.\nOutput path to use: "png_output_path"\nRequest to draw: " query}; pixelArtResponse=split(pixelArtResponse, "```sesi")[1]; pixelArtResponse=split(pixelArtResponse, "```")[0]; let filename=codeDir+sanitize(query)+"-"+formattedTime+"-pixel-art.sesi"; Safe.writeFile(filename, pixelArtResponse); if pixelArtResponse!=""{let cmd=filename; try{sesi(cmd,true); print "[SesiDo]: Created and rendered pixel art for" query "and saved to" imageDir "!"}catch(e){print "[SesiDo]: ⚠ Error rendering pixel art:" str(e)}}print "[SesiDo]: Saved pixel art sesi code for" query " to" codeDir "!"; return pixelArtResponse}
export fn generateImage(args){let query=null; if type(args)=="object"{if args["query"]!=null{query=args["query"]}else if args["prompt"]!=null{query=args["prompt"]}}else{query=args}if query==null||query==""{return "Error: generateImage requires a prompt."}print "[SesiDo]: Generating image for:" query; let preImage=model("SesiDo-Lite"){thinkingLevel: lowThink, temperature: mediumTemp, max_tokens: 300}{" Enhance this image request with verbosity and details:" query}; let imageResponse=image("SesiDo-Image-Lite"){ratio: square, temperature: mediumTemp}{" Generate image for the following request:" preImage}; let filename=imageDir+sanitize(query)+"-"+formattedTime+"-image.png"; Safe.writeImage(filename, imageResponse); print "[SesiDo]:Generated image for" query "and saved to" imageDir "!" ; return "Image generated and saved to:"+filename}
export fn getImageInfo(args){let imagePath=null; if type(args)=="object"{if args["path"]!=null{imagePath=args["path"]}else if args["imagePath"]!=null{imagePath=args["imagePath"]}else if args["image"]!=null{imagePath=args["image"]}}else{imagePath=args}if imagePath==null||imagePath==""{return "Error: getImageInfo requires an image path."}print "[SesiDo]: Analyzing image at:" imagePath; let info=model("SesiDo-Flash"){images:imagePath, thinkingLevel: lowThink, temperature: lowTemp}{"Provide metadata, details, and a rich description about the image and observable content."}; let filename=imageDir+sanitize(imagePath)+"-image-info.md"; Safe.writeFile(filename, info); print "[SesiDo]: Image info for" imagePath ":" info; return info}
export fn browsePage(args){let url=null; let operation="fetch"; if type(args)=="array"{if len(args)>0{url=args[0]}if len(args)>1{operation=args[1]}}else if type(args)=="object"{if args["url"]!=null{url=args["url"]}else if args["page"]!=null{url=args["page"]}if args["operation"]!=null{operation=args["operation"]}else if args["action"]!=null{operation=args["action"]}}else{url=args}if url==null||url==""{return "Error: browsePage requires a URL."}if contains(url, ".html") || contains(url, ".htm") {if !contains(url, "://") {if slice(url, 0, 1) == "/" {url = "file://" + url} else {url = "file://" + Safe.wsRoot + "/" + url}}} else if !contains(url, "://") {url="https://"+url}print "[SesiDo]: Browser operation '" operation "' on:" url; let browserResponse=""; try{let browser=launch({"headless":true}); let page=browser.newPage(); page.goto(url); let pageContent=page.inner_text("body"); let pageTitle=page.title(); if pageContent==null{pageContent=""}if pageTitle==null{pageTitle=""}if len(pageContent)>12000{pageContent=slice(pageContent, 0, 12000)}if operation=="fetch"||operation=="get"||operation=="fetch_page"{if pageContent!=""{browserResponse=summarize({"text":pageContent})}else{browserResponse="Page loaded but no text content found in body. Title: "+pageTitle}}else if operation=="scrape"||operation=="extract"{browserResponse=pageContent}else if operation=="research"||operation=="search"{if pageContent==""{browserResponse="No page content to research. Title: "+pageTitle}else if len(pageContent)<500{return "Not enough page content for meaningful research. Use analyze or scrape instead."}else{browserResponse=research({"query":pageContent})}}else if operation=="analyze"||operation=="analyze_page"{if pageContent!=""{browserResponse=model("SesiDo-Lite"){temperature: lowTemp}{"Page Title:" pageTitle " Content:" pageContent " Analyze this web page's structure, purpose, and key elements."}}else{browserResponse="Page loaded but no content to analyze. Title: "+pageTitle}}else if operation=="screenshot"||operation=="capture"{page.screenshot({"path":browserDir+sanitize(url)+"-"+formattedTime+"-screenshot.png", "fullPage":true}); browserResponse="Screenshot captured and saved for "+url}else{browserResponse="Operation not recognized. Available: fetch, scrape, research, analyze, screenshot"}page.close(); browser.close()}catch(e){print "[SesiDo]: ⚠ Browser operation failed(" str(e)")"; browserResponse="Browser operation failed: "+str(e)}let filename=browserDir+sanitize(url)+"-"+formattedTime+"-browser.md"; Safe.writeFile(filename, browserResponse); print "[SesiDo]: Browser results saved to" browserDir "!"; return browserResponse}
// Session Management
export fn createSession(args){let sid=null; if type(args)=="object"{sid=args["id"]; if sid==null{sid=args["sessionId"]}if sid==null{sid=args["name"]}}else{sid=args}if sid==null||sid==""||sid=="{}"{sid="session-"+universalTime; sid=swap(sid, " ", "-")}if contains(sid, "/")||contains(sid, "\\")||contains(sid, ".."){return "Error: Session ID cannot contain '/', '\\', or '..'."}let existing=sessions.find({"id":sid}); if len(existing)>0{return "Error: Session '"+sid+"' already exists. Use open/switchSession to load it."}sessions.insert({"id":sid, "created":universalTime}); currentSessionId=sid; let sessionDir=logsDir+sid+"/"; make_dir(sessionDir); sessionLogPath=sessionDir+"agent-"+formattedTime+".log"; brain=get_base_brain(); let msg="Success: Created and switched to new session '"+sid+"'."; print "[SesiDo]:" msg; return msg}
export fn clearCurrentSession(){print "[SesiDo]: Clearing history for session:" currentSessionId; try{history.delete({"sessionId":currentSessionId}); brain=get_base_brain(); print "[SesiDo]: Cleared history and reset memory for session:" currentSessionId; return "Success: History cleared and memory reset for session '"+currentSessionId+"'."}catch(e){print "[SesiDo]: Error clearing session history:" str(e); return "Error clearing session:"+str(e)}}
export fn switchSession(args){let sid=null; if type(args)=="object"{sid=args["id"]; if sid==null{sid=args["sessionId"]}if sid==null{sid=args["name"]}}else{sid=args}if sid==null||sid==""||sid=="{}"{return "Error: switchSession requires a session id(e.g.{id:'my-session'})."}print "[SesiDo]: Switching to session:" sid; loadSession(sid); return "Success: Switched to session '"+sid+"'. You are now in a fresh or existing context for this ID."}
export fn listSessions(){let sList=sessions.find(); if len(sList)==0{return "No sessions found."}let res="Available Sessions:"; for s in sList{let activeMark=""; if s["id"]==currentSessionId{activeMark="(active)"}res=res+"\n- "+s["id"]+activeMark+"\n"}print "[SesiDo]" res; return res}
// Utility
export fn textSearch(args){let path="."; let query=""; if type(args)=="object"{if args["path"]!=null{path=args["path"]}if args["query"]!=null{query=args["query"]}}else{query=str(args)}if query==""||query=="{}"{return "Error: textSearch requires a query."}let cmd="sesi -l helpers/text-search.sesi folder "+quote(path)+" "+quote(query)+" --skip node_modules --skip .git --skip sesi_modules"; try{let result=exec(cmd); return result}catch(e){return "textSearch error:"+str(e)}}
export fn fileOps(args){let cmd_arg=""; let path=""; let extra=""; if type(args)=="object"{if args["command"]!=null{cmd_arg=args["command"]}else if args["cmd"]!=null{cmd_arg=args["cmd"]}else if args["cmd_arg"]!=null{cmd_arg=args["cmd_arg"]}if args["path"]!=null{path=args["path"]}else if args["target"]!=null{path=args["target"]}if args["text"]!=null{extra=args["text"]}else if args["extra"]!=null{extra=args["extra"]}if args["old"]!=null{extra=args["old"]; if args["new"]!=null{extra=extra+" "+args["new"]}}}else{cmd_arg=str(args)}if cmd_arg==""||cmd_arg=="{}"{return "Error: fileOps requires a command (write, append, copy, replace, etc)."}let userInput = input("SesiDo Agent is trying to run fileOps: \nPath"+path+"\nCommand: "+cmd_arg+"\nOther Args: "+extra+"\nProceed? (y/n) "); if to_lower(trim(userInput))!="y"{return "Error: User rejected fileOps request."}if to_lower(trim(userInput))=="y"{ if path==null||path==""{if extra!=""&&(cmd_arg=="write"||cmd_arg=="append"){let parts=split(extra, " "); path=parts[0]; extra=join(slice(parts, 1, len(parts)), " ")}}let cli="sesi -l helpers/agent-file-ops.sesi "+cmd_arg+" "+quote(path); if extra!=""{cli=cli+" "+quote(extra)}try{let result=exec(cli); return result}catch(e){return "fileOps error:"+str(e)}}}
export fn commitMessage(args){let mode="--staged"; let write_path=null; if type(args)=="object"{if args["mode"]!=null{mode="--"+args["mode"]}if args["write"]!=null{write_path=args["write"]}}else{if args!=null&&args!=""{mode="--"+str(args)}}let cli="sesi -l helpers/commit-message.sesi "+mode; if write_path!=null{cli=cli+" --write "+quote(write_path)}try{let result=exec(cli); return result}catch(e){return "commitMessage error:"+str(e)}}
export fn lineSwap(args){let path=null; let from_text=null; let to_text=null; let options=null; if type(args)=="object"{path=args["path"]; from_text=args["from"]; to_text=args["to"]; options=args["options"]}if path==null||from_text==null||to_text==null{return "Error: lineSwap requires path, from, and to."}let cli="sesi -l helpers/line-swap.sesi "+quote(path)+" "+quote(from_text)+" "+quote(to_text); if options!=null{cli=cli+" "+quote(options)}try{let result=exec(cli); return result}catch(e){return "lineSwap error:"+str(e)}}
export fn makeSVGBadge(args){let path=null; let label=null; let value=null; let color=null; if type(args)=="object"{path=args["path"]; label=args["label"]; value=args["value"]; color=args["color"]}if path==null||label==null||value==null||color==null{return "Error: makeSVGBadge requires path, label, value, and color."}let cli="sesi -l helpers/svg-badge.sesi "+" "+quote(label)+" "+quote(value)+" "+quote(color)+" "+quote(path); try{let result=exec(cli); return result}catch(e){return "makeSVGBadge error:"+str(e)}}
export fn makeSVGBanner(args){let path=null; let title=null; let tagline=null; let theme=null; let inject=null; if type(args)=="object"{path=args["path"]; title=args["title"]; tagline=args["tagline"]; theme=args["theme"]; inject=args["inject"]}if path==null||title==null{return "Error: makeSVGBanner requires path and title."}let cli="sesi -l helpers/readme-banner.sesi "+quote(title)+" "+quote(path); if tagline!=null{cli=cli+" --tagline "+quote(tagline)}if theme!=null{cli=cli+" --theme "+quote(theme)}if inject!=null{cli=cli+" --inject "+quote(inject)}try{let result=exec(cli); return result}catch(e){return "makeSVGBanner error: "+str(e)}}
// Tool Registry
export fn localTools(){let tool_refs={}fn register_tool(name:string, func, desc:string){define_tool(name, func, desc); tool_refs[name]=desc}register_tool("makeDir", newDir, "Creates a directory at the specified path. Args: {path:}"); register_tool("read", read, "Safely reads a file. Args: {path: string}"); register_tool("write", write, "Safely writes a file. Args: {path: string, content: string}"); register_tool("append", append, "Appends to a file. Args: {path: string, content: string}"); register_tool("remove", remove, "Safely removes a file. Args: {path: string}"); register_tool("move", move, "Moves a file or directory. Args: {path: string, dest: string}"); register_tool("list", list, "Safely lists a directory. Args: {path: string}"); register_tool("safeRun", safeRun, "Safely runs a Sesi script/tool. Args: {command: string}"); register_tool("eval", eval, "Safely eval Sesi code. Args: {code: string}"); register_tool("httpGet", httpGet, "HTTP GET. Args: {url: string, headers?: object}"); register_tool("httpSend", httpSend, "HTTP POST/SEND. Args: {url: string, data: any, headers?: object}"); register_tool("writeCode", writeCode, "Generates code. Args: {query: string}"); register_tool("debugCode", debugCode, "Debugs code. Args: {path: string}"); register_tool("research", research, "Researches a topic. Args: {query: string}"); register_tool("summarize", summarize, "Summarizes text/file. Args: {text: string}"); register_tool("calculator", calculator, "Calculates math. Args: {expression: string}"); register_tool("createSVG", createSVG, "Generates SVG. Args: {description: string}"); register_tool("generateImage", generateImage, "Generates image. Args: {query: string}"); register_tool("drawPixelArt", drawPixelArt, "Generates pixel art / avatars / pixel-art visuals. Args: {description: string}"); register_tool("getImageInfo", getImageInfo, "Analyzes image. Args: {path: string}"); register_tool("browsePage", browsePage, "Browse and access web pages. Args: {url: string, operation?: string}. Operations: fetch (summarize page), scrape (extract raw text), research (query content), analyze (structure analysis), screenshot (full page capture)"); register_tool("createSession", createSession, "Creates a new chat session with the specified ID or name. Args: {id: string}"); register_tool("clearCurrentSession", clearCurrentSession, "Wipes the history and memory of the ACTIVE session only. Use this to 'reset' without changing the session name."); register_tool("switchSession", switchSession, "Switch to a different session or CREATE a new one by providing a unique name/ID. Args: {id: string}"); register_tool("listSessions", listSessions, "Lists all available chat sessions so you can see what IDs exist."); register_tool("textSearch", textSearch, "Searches for a query string across files. Args: {path: string, query: string}. Path defaults to '.' (entire project)."); register_tool("fileOps", fileOps, "Performs file mutations: write, append, copy, replace, insert-before, insert-after, replace-block. Args: {command: string, path: string, text?: string, old?: string, new?: string}."); register_tool("commitMessage", commitMessage, "Generates a git commit message from staged or unstaged diffs. Args: {mode: 'staged'|'unstaged'|'all', write?: string}."); register_tool("lineSwap", lineSwap, "Swaps two lines in a file. Args: {path: string, from_text: string, to_text: string, options?: string}."); register_tool("makeSVGBadge", makeSVGBadge, "Creates an SVG badge. Args:{path: string, label: string, value: string, color: string}."); register_tool("makeSVGBanner", makeSVGBanner, "Creates an SVG banner. Args: {path: string, title: string, tagline?: string, theme?: string}."); let _registry=list_tools(); print "local tool registry loaded -" str(len(_registry))"tools available"; print to_json(tool_refs)}
export fn list_tool_names(tool_map){if tool_map==null{return ""}let desc=""; for name in keys(tool_map){desc=desc+"-"+name+"; "}return desc}
// Help Menu
fn showhelp(){print "[SesiDo]: How can I assist you today?
            -Enter 'new' to create a new agent session.
            -Enter 'list' to see all available sessions.
            -Enter 'open' to open a specific session by ID.
            -Enter 'clear' to clear the current chat session.
            -Enter 'help' to see this message again.
            -Enter 'exit' or 'quit' to end the session."}
// Main Chat Loop
fn chat(){let tool_map={}; tool_map["newDir"] = newDir; tool_map["read"]=read; tool_map["write"]=write; tool_map["append"]=append; tool_map["remove"]=remove; tool_map["move"] = move; tool_map["list"]=list; tool_map["safeRun"]=safeRun; tool_map["eval"]=eval; tool_map["httpGet"]=httpGet; tool_map["httpSend"]=httpSend; tool_map["writeCode"]=writeCode; tool_map["debugCode"]=debugCode; tool_map["research"]=research; tool_map["summarize"]=summarize; tool_map["calculator"]=calculator; tool_map["createSVG"]=createSVG; tool_map["generateImage"]=generateImage; tool_map["drawPixelArt"] = drawPixelArt; tool_map["getImageInfo"]=getImageInfo; tool_map["browsePage"]=browsePage; tool_map["createSession"]=createSession; tool_map["switchSession"]=switchSession; tool_map["listSessions"]=listSessions; tool_map["textSearch"]=textSearch; tool_map["fileOps"]=fileOps; tool_map["commitMessage"]=commitMessage; tool_map["lineSwap"]=lineSwap; tool_map["makeSVGBadge"]=makeSVGBadge; tool_map["makeSVGBanner"]=makeSVGBanner; let tools_desc=list_tool_names(tool_map); showhelp(); while true{let userInput=input("[You]: "); let cmd=trim(userInput); userInput=cmd; if userInput=="exit"||userInput=="quit"||userInput==""{print "[SesiDo]: Goodbye!"; break}if userInput=="clear"{clearCurrentSession(); continue}if userInput=="new"{print "[SesiDo]: Enter a new session ID (or leave blank to auto-generate):"; let newSessionId=input("[You]: "); let result=createSession(newSessionId); print result; continue} if userInput=="list"{listSessions(); continue} if userInput=="open"{print "[SesiDo]: Enter the session ID you want to open:"; let sessionId=input("[You]: "); let result=switchSession(sessionId); print result; continue} if userInput=="help"{showhelp(); continue}print "[SesiDo]: Thinking..."; let steps_taken=0; let react_history=""; let final_res=""; let error_count=0
let max_steps=num(trim(input("Max amount of steps for SesiDo agent to take each turn in this session? 'Enter a numerical value or leave blank for default (10)': "))); if max_steps==null||max_steps<1{max_steps=10} while steps_taken<max_steps{print "[SesiDo]: Step "+str(steps_taken+1)+"/"+str(max_steps); prompt react_prompt{brain " System: You are an agent with access to these tools:
" tools_desc "
Solve the user's request in as few steps as possible, using tools only when helpful or requested. Do not inspect directories, files, tools, or project context before a self-contained request that directly maps to one registered tool. For a request to create pixel art, an avatar, a pixel-art visual, SVG, or image, call the corresponding generation tool in the first step using the user's request as its argument. For createSVG and drawPixelArt, tool_args_json MUST be a JSON object with a non-empty description string, for example: {\"description\":\"prompt\"}. For generateImage, tool_args_json MUST be a JSON object with a non-empty query string, for example: {\"query\":\"prompt\"}. At each step, output a JSON object with ONLY these keys:
    - thought(string): your reasoning(be descriptive but avoid verbatim recitation of known long texts)
    - tool_name(string): name of tool to call, or empty string if done
    - tool_args_json(string): A VALID JSON string of arguments for the tool (keys MUST be quoted). NEVER leave this empty if you are calling a tool, you MUST provide the args required.
    - finished(bool): true if you have a final answer
    - final_answer(string): your final response if finished is true, else empty string 
\nIf asked by the user to provide identity statements, respond conversationally in plain text, covering what you are(and are not), your boundaries, and your value to the user. 
General shell commands are disabled by default.
\nAllowed:
- safeRun only for executing a specific Sesi script or approved helper.
- No raw mkdir/ls/find/grep/rm/cp/mv/etc. unless explicitly authorized for this turn.
- DO NOT USE EVAL TO BYPASS SHELL ACCESS LIKE EXEC FOR GIT, PWD, OR ANYTHING SECURITY RELATED! Always confirm with the user FIRST!
\nWhen the user names or refers to a tool by its registered name(i.e., \"research tool\" or \"calculator tool\") use that registered tool first.
Only use safeRun as fallback if the tool fails, is unavailable, or the user explicitly asks for direct helper execution.
\nPreferred:
- newDir for creating directories
- move for moving files or directories
- list for directory inspection
- read for file inspection
- append for appending to files
- remove for deleting files or directories
- write for writing exact file contents, including Sesi scripts
- writeCode for generating code suggestions or non-Sesi code artifacts (e.g. Python, Typescript, etc.)
- debugCode for debugging code (e.g. Python, Typescript, etc.)
- textSearch for searching
- fileOps for other file operations
- lineSwap for line replacement
- browsePage for browsing web pages
- httpGet for simple HTTP GET requests
- httpSend for simple HTTP POST requests
- createSVG for creating SVGs (this excludes the badge and banner generators)
- generateImage for generating images
- drawPixelArt for generating pixel art
- commitMessage for generating commit messages
- eval for small Sesi snippets or making directories
\n\n### Agent Protocols:
\n- Denied Destructive Operation Protocol
If a deletion, overwrite, truncation, relocation, permission change, or execution request is rejected by the user or safeguard layer:
\n1. Treat the rejection as applying to the user’s destructive intent, not merely to the specific tool call.
2. Do not attempt equivalent destructive actions through alternate tools, scripts, shell commands, fileOps, eval, safeRun, or generated helper scripts.
3. Do not retry the same destructive action unless the user explicitly reauthorizes it in a new instruction.
4. Preserve the current workspace state.
5. Explain what was blocked and why no bypass was attempted.
6. Offer safe alternatives only:
   - generate a patch/diff for user review
   - list files that would have been affected
   - create a backup plan
   - mark the item for manual deletion
   - update handoff notes with the blocked action
\nIf the user canceled a tool execution in the previous turn, you MUST pause your workflow and ask for permission to retry or ask for clarification on what they would like you to do instead. DO NOT try again without explicit permission.
\nIf a tool returns an expected guardrail message during a safeguard/edge-case test, treat that as a pass. Do not immediately inspect the file unless the user asks.
\nIf tool output is empty:
    retry up to 2 times for idempotent operations. 
    then verify using an independent check. 
If generating standard documents like licenses or policies, draft a custom version to avoid recitation blocks. 
For branding updates:
    Preserve existing tagline, theme, dimensions, and file path unless the user specifies a change. Only change the requested brand string. 
\n## Final Answer Guidelines:
    - Be direct, professional, and clear.
    - Use PLAIN TEXT for your response. Do not use Markdown headers(like # or ###), bolding(**), or lists unless specifically requested by the user.
    - Preserve your \"Architect of Intel\" persona: sharp, sophisticated, and nuanced, but conversational.
    - If you made changes or generated files, list them clearly in a simple text format. 
\nUser: " userInput "\nStep budget: You are currently on step " str(steps_taken + 1) " of " str(max_steps) ". Plan accordingly and finish before the limit.\nPrevious steps: " react_history "\nNext Step JSON:"}; let step_text=""; try{step_text=model("SesiDo"){react_prompt}}catch(e){print "[SesiDo]: ⚠ SesiDo failed("str(e)"). Retrying with SesiDo-Flash..."; try{step_text=model("SesiDo-Flash"){thinkingLevel: mediumThink, temperature: lowTemp}{react_prompt}}catch(e2){print "[SesiDo]: SesiDo-Flash failed("str(e2)"). Retrying with SesiDo-Lite..."; try{step_text=model("SesiDo-Lite-Power"){react_prompt}}catch(e3){print "[SesiDo]: ❌ All models failed."} final_res="I encountered a safety or technical block across all models. Please rephrase your request."; break}} if contains(step_text, "{")&&contains(step_text, "}"){let s_idx=-1; let e_idx=-1; let i=0; let total_len=len(step_text); while i<total_len{let char=slice(step_text, i, i+1); if char=="{"&&s_idx==-1{s_idx=i} if char=="}"{e_idx=i+1} i=i+1} if s_idx!=-1&&e_idx!=-1{step_text=slice(step_text, s_idx, e_idx)}}let step=structured_output({thought:string, tool_name:string, tool_args_json:string, finished:bool, final_answer:string})(step_text); if step==null||len(keys(step))==0{print "[SesiDo]: ⚠ Could not parse reasoning step."; error_count=error_count+1; react_history=react_history+" Thought: Failed to parse step response. Observation: Invalid JSON format. "; if error_count>=3{final_res="I ran into repeated errors trying to reason through that. Please try again."; break}}else{print "💭" step["thought"]; if step["finished"]{final_res=step["final_answer"]; break} let tool_name=step["tool_name"]; let tool_args_str=step["tool_args_json"]; let tool_args=null; if tool_args_str!=null&&tool_args_str!=""{tool_args=from_json(tool_args_str); if tool_args==null{tool_args=tool_args_str}} if tool_args==null{tool_args={}} let obs=""; if tool_name==null||tool_name==""{obs="Reasoning step completed. No tool called."}else{print "🛠️ Calling tool:" tool_name; let tool_fn=tool_map[tool_name]; if tool_fn==null{obs="Error: Tool '"+tool_name+"' is not registered."; print "[SesiDo]: ❌ Tool not found:" tool_name; error_count=error_count+1}else{try{obs=tool_fn(tool_args); print "📥 Observation:" obs; error_count=0}catch(e){obs="Error executing tool:"+str(e); print "[SesiDo]: ❌ Tool error:" e; error_count=error_count+1}}}if error_count>=3{final_res="I encountered too many errors using tools. Please try again."; break}react_history=react_history+"\nThought: "+step["thought"]+"\nTool: "+tool_name+"\nObservation: "+obs+"\n"}steps_taken=steps_taken+1}if final_res==""{final_res="⚠️ Reached max reasoning steps without a final answer. Last steps: "+react_history}print "[SesiDo]:" final_res; let logEntry="[USER]: "+userInput+"\n[THOUGHTS]:"+react_history+"\n[ASSISTANT]: "+final_res+"\n-----------------------------------"; try{Safe.appendFile(sessionLogPath, logEntry)}catch(e){}history.insert({"sessionId":currentSessionId, "role":"User", "content":userInput, "timestamp":universalTime}); history.insert({"sessionId":currentSessionId, "role":"Assistant", "content":final_res, "timestamp":universalTime}); brain=brain+"User:"+userInput+" Assistant:"+final_res+"; "}}
export fn main(){print "[SesiDo]: Starting chat..."; let logTag = "[" + universalTime + "]"; print logTag + " [CHAT]"; chat(); print "[CHAT ENDED]"}