{
  "name": "SesiDo",
  "version": "1.1.0",
  "description": "SesiDo - Native Sesi Autonomous Agent",
  "main": "index.sesi",
  "scripts": {
    "start": "sesi --cli -l main.sesi",
    "research": "sesi --cli -l agent/ops/research.sesi",
    "browser": "sesi --cli -l agent/ops/browser.sesi",
    "summarize": "sesi --cli -l agent/ops/summarize.sesi",
    "debug": "sesi --cli -l agent/ops/debug.sesi",
    "gen:code": "sesi --cli -l agent/generate/coder.sesi",
    "gen:image": "sesi --cli -l agent/generate/image.sesi",
    "gen:pixel": "sesi --cli -l agent/generate/pixel-art.sesi",
    "gen:svg": "sesi --cli -l agent/generate/svg.sesi",
    "calculator": "sesi --cli -l agent/math/calculator.sesi"
  },
  "keywords": [
    "ai",
    "sesi",
    "intelligence"
  ]
}