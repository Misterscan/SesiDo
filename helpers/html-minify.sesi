/*
  Sesi HTML Minifier
  
  Safely strips whitespace while preserving structural newlines to 
  protect inline JavaScript comments (//) and <pre> block formatting.
  Supports both single-file targeting and full-directory batch processing.

  Usage:
    sesi html-minify.sesi [input_file_or_dir] [output_dir]
*/

let input_target = "index.html"
let output_dir = "minified"

if len(args) > 0 { input_target = args[0] }
if len(args) > 1 { output_dir = args[1] }

// Ensure output directory exists safely
try {
  make_dir(output_dir)
} catch (err) {}

fn minify_html(html: string) -> string {
  // 1. Normalize carriage returns
  let normalized = swap(html, "\r", "")
  
  // Create a literal newline variable for safe cross-platform splitting
  let newline = "
"
  let lines = split(normalized, newline)
  let minified_lines = []
  
  // 2. Process line-by-line with a basic state machine
  let in_pre = false
  
  for line in lines {
    if contains(line, "<pre>") {
      in_pre = true
    }
    
    if in_pre {
      // Preserve the line exactly to protect code indentation
      push(minified_lines, line)
    } else {
      // Trim leading/trailing whitespace everywhere else
      let trimmed = trim(line)
      if len(trimmed) > 0 {
        push(minified_lines, trimmed)
      }
    }
    
    if contains(line, "</pre>") {
      in_pre = false
    }
  }
  
  // 3. Join with newlines to protect JS single-line comments
  let joined = join(minified_lines, newline)
  
  // 4. Safely collapse consecutive spaces
  let prev_spaces = ""
  while prev_spaces != joined {
    prev_spaces = joined
    joined = swap(joined, "  ", " ")
  }
  
  // 5. Safely close gaps between consecutive HTML tags across line breaks
  prompt tag_gap {">" newline "<"}
  
  let prev_tags = ""
  while prev_tags != joined {
    prev_tags = joined
    joined = swap(joined, tag_gap, "><")
  }
  
  // Also close gaps for tags separated by a single space
  let prev_inline = ""
  while prev_inline != joined {
    prev_inline = joined
    joined = swap(joined, "> <", "><")
  }
  
  return joined
}

// Reusable I/O worker block
fn process_file(in_path: string, out_path: string) {
  print "Processing:" in_path
  try {
    let source_html = read_file(in_path)
    let minified_html = minify_html(source_html)
    let success = write_file(out_path, minified_html)
    
    if success {
      print "  -> Saved:" out_path "(" len(minified_html) "bytes )"
    }
  } catch (err) {
    print "  -> File I/O Error processing" in_path ":" err
  }
}

// ---------------------------------------------------------
// Execution Routing
// ---------------------------------------------------------

if contains(input_target, ".html") {
  print "Running in Single File Mode..."
  
  // Cleanly extract the filename from the path
  let path_parts = split(input_target, "/")
  let filename = pop(path_parts)
  
  prompt target_out {output_dir "/" filename}
  process_file(input_target, target_out)
  
} else {
  print "Running in Batch Directory Mode..."
  print "Scanning directory:" input_target
  
  try {
    let files = list_dir(input_target)
    let count = 0
    
    for file in files {
      if contains(file, ".html") {
        prompt target_in {input_target "/" file}
        prompt target_out {output_dir "/" file}
        
        process_file(target_in, target_out)
        count = count + 1
      }
    }
    
    print "Batch HTML minification complete. Processed" count "files."
  } catch (err) {
    print "Error reading directory. Ensure the path exists and permissions are valid." err
  }
}