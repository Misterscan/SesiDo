/*
    Sesi-native module dependency analyzer.

Usage:
    sesi helpers/dependency-graph.sesi <entry_file> [options]

Options:
    --svg <file>   Output a beautiful SVG flow diagram (default: dependency-graph.svg)
    --json <file>  Save graph data in JSON format
    --all          Include Sesi standard library modules (std/*)
    --help         Show this help menu
*/

allow "std/draw" in with Draw
allow "std/math" in with Math

fn show_help() {
  print "Sesi Dependency Graph Analyzer"
  print ""
  print "Usage:"
  print "  sesi helpers/dependency-graph.sesi <entry_file> [options]"
  print ""
  print "Options:"
  print "  --svg <file>   Output a beautiful SVG flow diagram (default: dependency-graph.svg)"
  print "  --json <file>  Save graph data in JSON format"
  print "  --all          Include Sesi standard library modules (std/*)"
  print "  --help         Show this help menu"
  print ""
  print "Examples:"
  print "  sesi helpers/dependency-graph.sesi examples/main/16_modules.sesi"
  print "  sesi helpers/dependency-graph.sesi main/tests/test_general_modules.sesi --all"
}

export fn get_dirname(path: string) -> string {
  let parts = split(path, "/")
  if len(parts) <= 1 {
    return "."
  }
  let dir_parts = slice(parts, 0, len(parts) - 1)
  return join(dir_parts, "/")
}

export fn join_paths(dir: string, file: string) -> string {
  if dir == "." {
    return file
  }
  return dir + "/" + file
}

export fn normalize_path(path: string) -> string {
  let is_absolute = false
  if len(path) > 0 {
    if slice(path, 0, 1) == "/" {
      is_absolute = true
    }
  }
  
  let parts = split(path, "/")
  let clean_parts = []
  for part in parts {
    if part == "." {
      // Ignore
    } else if part == ".." {
      if len(clean_parts) > 0 {
        clean_parts = slice(clean_parts, 0, len(clean_parts) - 1)
      }
    } else if part != "" {
      push(clean_parts, part)
    }
  }
  let result = join(clean_parts, "/")
  if is_absolute {
    return "/" + result
  }
  return result
}

fn file_exists(path: string) -> bool {
  try {
    read_file(path)
    return true
  } catch (err) {
    return false
  }
}

fn get_home_dir() -> string {
  try {
    let out = exec("echo $HOME")
    if out != null {
      return trim(out)
    }
  } catch (e) {
  }
  try {
    let out = exec("echo %USERPROFILE%")
    if out != null {
      return trim(out)
    }
  } catch (e) {
  }
  return null
}

fn get_sesi_path() -> string {
  try {
    let out = exec("echo $SESI_PATH")
    if out != null {
      return trim(out)
    }
  } catch (e) {
  }
  try {
    let out = exec("echo %SESI_PATH%")
    if out != null {
      return trim(out)
    }
  } catch (e) {
  }
  return null
}

fn resolve_path(source: string, importing_file: string) -> string {
  let filename = source
  let len_name = len(filename)
  let has_ext = false
  if len_name >= 5 {
    if slice(filename, len_name - 5) == ".sesi" {
      has_ext = true
    }
  }
  if has_ext == false {
    filename = filename + ".sesi"
  }
  
  let search_dirs = []
  
  let dir = get_dirname(importing_file)
  push(search_dirs, dir)
  
  push(search_dirs, ".")
  
  let sp = get_sesi_path()
  if sp != null && sp != "" && sp != "%SESI_PATH%" && sp != "$SESI_PATH" {
    let sep = ":"
    if contains(sp, ";") {
      sep = ";"
    }
    let parts = split(sp, sep)
    for p in parts {
      if p != "" {
        push(search_dirs, p)
      }
    }
  }
  
  let home = get_home_dir()
  if home != null && home != "" && home != "%USERPROFILE%" && home != "$HOME" {
    let global_lib = join_paths(home, ".sesi/lib")
    push(search_dirs, global_lib)
  }
  
  for d in search_dirs {
    let resolved = normalize_path(join_paths(d, filename))
    if file_exists(resolved) {
      return resolved
    }
  }
  
  return normalize_path(join_paths(dir, filename))
}

export fn extract_module(line: string) -> string {
  let kw_pos = locate(line, "allow")
  let kw_len = 5
  if kw_pos == -1 {
    kw_pos = locate(line, "import")
    kw_len = 6
  }
  
  if kw_pos == -1 {
    return null
  }
  
  let comment_pos = locate(line, "//")
  if comment_pos != -1 {
    if comment_pos < kw_pos {
      return null
    }
  }
  
  let line_after = slice(line, kw_pos + kw_len)
  let q_pos = locate(line_after, "\"")
  let quote_char = "\""
  if q_pos == -1 {
    q_pos = locate(line_after, "'")
    quote_char = "'"
  }
  if q_pos == -1 {
    return null
  }
  let start = kw_pos + kw_len + q_pos + 1
  let rest = slice(line, start)
  let end_rel = locate(rest, quote_char)
  if end_rel == -1 {
    return null
  }
  let mod = slice(line, start, start + end_rel)
  if contains(mod, "\\") {
    return null
  }
  return mod
}

let graph = {}
let visited = {}

fn scan_recursive(file_path: string, parent_file: string, options) {
  let norm_path = normalize_path(file_path)
  
  if visited[norm_path] != null {
    return null
  }
  visited[norm_path] = true
  
  let content = ""
  try {
    content = read_file(norm_path)
  } catch (err) {
    if parent_file != null {
      print "⚠️ Module file not found or unreadable:" norm_path " (imported by" parent_file ")"
    } else {
      print "⚠️ Module file not found or unreadable:" norm_path
    }
    graph[norm_path] = []
    return null
  }
  
  let lines = split(content, "
")
  let deps = []
  
  for line in lines {
    let mod = extract_module(line)
    if mod != null {
      let is_std = false
      if len(mod) >= 4 {
        if slice(mod, 0, 4) == "std/" {
          is_std = true
        }
      }
      
      let resolved = mod
      if is_std == false {
        resolved = resolve_path(mod, norm_path)
      }
      
      if is_std == false || options["all"] == true {
        let found = false
        for existing in deps {
          if existing == resolved {
            found = true
          }
        }
        if found == false {
          push(deps, resolved)
        }
      }
    }
  }
  
  graph[norm_path] = deps
  
  for dep in deps {
    let is_dep_std = false
    if len(dep) >= 4 {
      if slice(dep, 0, 4) == "std/" {
        is_dep_std = true
      }
    }
    if is_dep_std == false {
      scan_recursive(dep, norm_path, options)
    }
  }
}

let circular_edges = {}

fn detect_cycles_dfs(node: string, path_stack: object) {
  let next_path = {}
  for key in keys(path_stack) {
    next_path[key] = true
  }
  next_path[node] = true
  
  let deps = graph[node]
  if deps != null {
    for dep in deps {
      if path_stack[dep] != null {
        let edge_key = node + "->" + dep
        circular_edges[edge_key] = true
      } else {
        detect_cycles_dfs(dep, next_path)
      }
    }
  }
}

fn print_tree(node: string, prefix: string, is_last: bool, branch_visited: object) {
  let connector = "├── "
  if is_last {
    connector = "└── "
  }
  
  let is_cycle = false
  if branch_visited[node] != null {
    is_cycle = true
  }
  
  let line_text = prefix + connector + node
  if is_cycle {
    line_text = line_text + " 🔁 (circular)"
  }
  print line_text
  
  if is_cycle {
    return null
  }
  
  let new_branch = {}
  for k in keys(branch_visited) {
    new_branch[k] = true
  }
  new_branch[node] = true
  
  let deps = graph[node]
  if deps != null {
    let next_prefix = prefix
    if is_last {
      next_prefix = next_prefix + "    "
    } else {
      next_prefix = next_prefix + "│   "
    }
    
    let count = len(deps)
    let i = 0
    while i < count {
      let dep = deps[i]
      let last = (i == count - 1)
      print_tree(dep, next_prefix, last, new_branch)
      i = i + 1
    }
  }
}

// Command execution flow
if len(args) == 0 {
  show_help()
} else {
  let entry_file = null
  let svg_file = "dependency-graph.svg"
  let json_file = null
  let include_all = false
  
  if args[0] == "--help" || args[0] == "-h" {
    show_help()
  } else {
    entry_file = args[0]
    
    // Parse options
    let idx = 1
    while idx < len(args) {
      let opt = args[idx]
      if opt == "--svg" {
        if idx + 1 < len(args) {
          svg_file = args[idx + 1]
          idx = idx + 2
        } else {
          print "⚠️ Missing value for --svg"
          idx = idx + 1
        }
      } else if opt == "--json" {
        if idx + 1 < len(args) {
          json_file = args[idx + 1]
          idx = idx + 2
        } else {
          print "⚠️ Missing value for --json"
          idx = idx + 1
        }
      } else if opt == "--all" {
        include_all = true
        idx = idx + 1
      } else {
        print "⚠️ Unknown option:" opt
        idx = idx + 1
      }
    }
    
    // Execute Analyzer
    let scan_opts = {
      "all": include_all
    }
    
    let norm_entry = normalize_path(entry_file)
    print "🔍 Scanning dependency graph starting from:" norm_entry
    scan_recursive(norm_entry, null, scan_opts)
    
    // Detect cycles
    detect_cycles_dfs(norm_entry, {})
    
    print ""
    print "📋 Dependency Tree:"
    print_tree(norm_entry, "", true, {})
    
    // Build union of all nodes
    let node_set = {}
    for k in keys(graph) {
      node_set[k] = true
      let dps = graph[k]
      if dps != null {
        for d in dps {
          node_set[d] = true
        }
      }
    }
    let nodes_list = keys(node_set)
    let n_nodes = len(nodes_list)
    
    // Render SVG
    Draw.clear()
    Draw.rect(0, 0, 1000, 800, "#0b0f19")
    
    // Assign coordinates
    let cx = 500
    let cy = 400
    let R = 280
    let node_coords = {}
    
    let n_idx = 0
    while n_idx < n_nodes {
      let name = nodes_list[n_idx]
      let nx = num(cx)
      let ny = num(cy)
      if n_nodes > 1 {
        let angle = (2.0 * Math.PI * num(n_idx)) / num(n_nodes)
        nx = num(cx) + num(R) * Math.cos(angle)
        ny = num(cy) + num(R) * Math.sin(angle)
      }
      node_coords[name] = {
        "x": nx,
        "y": ny
      }
      n_idx = n_idx + 1
    }
    
    // Draw edges
    for u in nodes_list {
      let deps = graph[u]
      if deps != null {
        for v in deps {
          let u_coords = node_coords[u]
          let v_coords = node_coords[v]
          if u_coords != null && v_coords != null {
            let x1 = u_coords["x"]
            let y1 = u_coords["y"]
            let x2 = v_coords["x"]
            let y2 = v_coords["y"]
            
            let edge_key = u + "->" + v
            let is_circular = (circular_edges[edge_key] != null)
            
            let stroke_color = "#3b82f6"
            let stroke_width = 2
            let opacity = 0.6
            if is_circular {
              stroke_color = "#ef4444"
              stroke_width = 3
              opacity = 0.9
            }
            
            // Draw dependency line
            Draw.line(x1, y1, x2, y2, stroke_color, {
              "stroke-width": stroke_width,
              "opacity": opacity
            })
            
            // Draw flow direction dot at 75% point
            let tx = x1 + 0.75 * (x2 - x1)
            let ty = y1 + 0.75 * (y2 - y1)
            Draw.circle(tx, ty, 5, stroke_color, {
              "opacity": opacity
            })
          }
        }
      }
    }
    
    // Draw cards on top
    for u in nodes_list {
      let u_coords = node_coords[u]
      if u_coords != null {
        let x = u_coords["x"]
        let y = u_coords["y"]
        let is_entry = (u == norm_entry)
        
        let is_std = false
        if len(u) >= 4 {
          if slice(u, 0, 4) == "std/" {
            is_std = true
          }
        }
        
        let w = 200
        let h = 45
        let rx = x - 100
        let ry = y - 22
        
        let bg_color = "#1f2937"
        let border_color = "#374151"
        let text_color = "#e5e7eb"
        
        if is_entry {
          border_color = "#10b981"
          text_color = "#10b981"
        } else if is_std {
          bg_color = "#111827"
          border_color = "#4b5563"
          text_color = "#9ca3af"
        }
        
        Draw.rect(rx, ry, w, h, bg_color, {
          "rx": 6,
          "ry": 6,
          "stroke": border_color,
          "stroke-width": 2
        })
        
        Draw.text(x, y + 4, u, 11, text_color, {
          "font-family": "system-ui, sans-serif",
          "text-anchor": "middle"
        })
      }
    }
    
    Draw.save_svg(svg_file, 1000, 800)
    print ""
    print "🎨 Beautiful SVG dependency graph saved to:" svg_file
    
    // Write JSON if requested
    if json_file != null {
      try {
        write_file(json_file, to_json(graph))
        print "💾 Dependency graph JSON data saved to:" json_file
      } catch (err) {
        print "⚠️ Error writing JSON file:" json_file " (" str(err) ")"
      }
    }
  }
}
